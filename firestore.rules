rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { 
      return request.resource.data; 
    }
    function existing() { 
      return resource.data; 
    }
    function isSignedIn() { 
      return request.auth != null; 
    }
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Validation for habit entity
    function isValidHabit(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'category', 'frequency', 'icon', 'createdAt', 'history', 'streak', 'maxStreak']) 
        && data.keys().size() == 10
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId == 'single-user'
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.category is string && (data.category == '건강' || data.category == '운동' || data.category == '학습' || data.category == '마음챙김')
        && data.frequency is string && (data.frequency == '매일' || data.frequency == '주 5회' || data.frequency == '주 3회' || data.frequency == '주 1회')
        && data.icon is string && data.icon.size() <= 50
        && data.createdAt is string && data.createdAt.size() <= 30
        && data.history is list && data.history.size() <= 1000
        && data.streak is int && data.streak >= 0
        && data.maxStreak is int && data.maxStreak >= 0;
    }

    match /habits/{habitId} {
      // Secure list queries and document access
      allow list: if true;
      allow get: if true;
      
      allow create: if isValidId(habitId) 
        && habitId == incoming().id
        && isValidHabit(incoming());
        
      allow update: if isValidId(habitId)
        && habitId == incoming().id
        && isValidHabit(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'icon', 'frequency', 'history', 'streak', 'maxStreak']);
        
      allow delete: if isValidId(habitId);
    }
  }
}
